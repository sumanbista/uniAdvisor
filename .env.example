COURSECOMPASS_DATABASE_URL=postgresql+psycopg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Storage defaults to local filesystem for development.
STORAGE_PROVIDER=local
# COURSECOMPASS_DOCUMENT_STORAGE_DIR=backend/storage/documents
# COURSECOMPASS_EXTRACTED_TEXT_DIR=backend/storage/extracted
# COURSECOMPASS_ALLOWED_UPLOAD_EXTENSIONS=.pdf,.txt,.md

# Supabase Storage is backend-only. Never expose SUPABASE_SERVICE_ROLE_KEY to frontend code.
# Set these only when STORAGE_PROVIDER=supabase.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<backend-only-service-role-key>
# SUPABASE_STORAGE_BUCKET=uniadvisor-documents

# COURSECOMPASS_CHUNK_SIZE=1000
# COURSECOMPASS_CHUNK_OVERLAP=200
# COURSECOMPASS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# BACKEND_CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.vercel.app

# Required for POST /rag/ask when an answer is generated.
GROQ_API_KEY=<your-groq-api-key>
COURSECOMPASS_GROQ_MODEL=qwen/qwen3-32b
# GROQ_MODEL=qwen/qwen3-32b
